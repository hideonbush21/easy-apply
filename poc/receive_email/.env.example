# QQ邮箱 IMAP 配置
IMAP_HOST=imap.qq.com
IMAP_PORT=993
IMAP_USER=your_qq@qq.com
# 授权码：QQ邮箱 → 设置 → 账户 → 开启 IMAP/SMTP → 生成授权码
IMAP_AUTH_CODE=your_qq_authorization_code
IMAP_FOLDER=INBOX

# 轮询间隔（秒）
POLL_INTERVAL_SECONDS=60

# UID 追踪方式：file（POC）或 redis（生产）
UID_STORE_TYPE=file
UID_FILE_PATH=processed_uids.json

# Redis（仅 UID_STORE_TYPE=redis 时需要）
REDIS_URL=

# LLM — Kimi (Moonshot)
# 申请地址：https://platform.moonshot.cn/
KIMI_API_KEY=your_kimi_api_key

# 附件保存目录（暂未使用，预留给生产集成）
ATTACHMENT_DIR=attachments
